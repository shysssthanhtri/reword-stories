# PostgreSQL connection (local Docker Compose — run `pnpm docker:up` first)
# Used by Next.js (t3-env), Prisma CLI (prisma.config.ts via dotenv), and @prisma/adapter-pg.
# Prisma CLI loads `.env` — copy this file to `.env`. Next.js also reads `.env.local`.
# For production, override DATABASE_URL with your hosted Postgres connection string.
DATABASE_URL="postgresql://reword:reword@localhost:5432/reword_stories"

# Middleware basic auth (v1 single-user access)
SITE_PASSWORD="change-me"

# Vercel AI Gateway (required for local LLM polish; optional on Vercel deploy via OIDC)
AI_GATEWAY_API_KEY="..."

# Direct provider keys (optional — future BYOK or native adapters)
OPENAI_API_KEY="sk-..."
GEMINI_API_KEY="..."
DEEPL_API_KEY="..."

# Modal Vietnamese correction provider (optional — required when using modal-vietnamese)
MODAL_VIETNAMESE_API_URL="https://your-workspace--reword-stories-vietnamese-correction-serve.modal.run"
MODAL_VIETNAMESE_API_KEY="..."

# Translation job in-workflow rate limit (optional — defaults shown)
CHUNK_POLISH_RATE_LIMIT=3
CHUNK_POLISH_RATE_LIMIT_WINDOW="60s"
