# PostgreSQL connection (local Docker Compose — run `pnpm docker:up` first)
# Used by Next.js (t3-env), Prisma CLI (prisma.config.ts via dotenv), and @prisma/adapter-pg.
# Prisma CLI loads `.env` — copy this file to `.env`. Next.js also reads `.env.local`.
# For production, override DATABASE_URL with your hosted Postgres connection string.
DATABASE_URL="postgresql://reword:reword@localhost:5432/reword_stories"

# Middleware basic auth (v1 single-user access)
SITE_PASSWORD="change-me"

# LLM provider API keys
OPENAI_API_KEY="sk-..."
GEMINI_API_KEY="..."
DEEPL_API_KEY="..."
